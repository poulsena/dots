# Set dwm status bar
while true
do
    xsetroot -name "Disk: $(df -h / | awk 'NR==2 {sub(/%/, "", $5); print $5}')% | $(date +"%a %b %d %H:%M")"
    sleep 1
done &

# relaunch DWM if the binary changes, otherwise bail
csum=""
new_csum=$(sha1sum $(which dwm))
while true
do
    if [ "$csum" != "$new_csum" ]
    then
        csum=$new_csum
        dwm
    else
        exit 0
    fi
    new_csum=$(sha1sum $(which dwm))
    sleep 0.5
done
